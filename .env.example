# AssistantX — required environment variables
# Copy this to .env and fill in your values

# ── DO Gradient AI (Serverless Inference) ────────────────────────────────────
# Get from: https://cloud.digitalocean.com/gradient/settings
DO_GRADIENT_API_KEY=

# Model to use for deep semantic scans (Layer 3 guardrail)
# DO_GRADIENT_MODEL=llama3.3-70b-instruct

# ── DO Gradient AI (Dedicated Inference — GPU) ───────────────────────────────
# For production deployments: route guardrail inference to a dedicated GPU
# (AMD MI300X 192GB or NVIDIA H100) for sub-100ms latency at scale.
# Create a Dedicated Inference deployment at:
#   https://cloud.digitalocean.com/gradient/dedicated-inference
# DO_GRADIENT_DEDICATED_ENDPOINT=https://<id>-public-dedicated-inference.do-infra.ai
# DO_GRADIENT_DEDICATED_TOKEN=

# ── DO Spaces (audit log) ────────────────────────────────────────────────────
# Create a Space at: https://cloud.digitalocean.com/spaces
# Then generate an access key at: https://cloud.digitalocean.com/account/api/spaces
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=assistantx-audit
DO_SPACES_REGION=nyc3

# ── AssistantX Authentication ─────────────────────────────────────────────────────
# Admin token for API access (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
ASSISTANTX_ADMIN_TOKEN=
# Dashboard login password
ASSISTANTX_ADMIN_PASSWORD=assistantx-demo-2026

# ── Auth0 Token Vault ────────────────────────────────────────────────────────
# Required for production. Without these, AssistantX runs in demo mode
# (no real OAuth flows, local placeholder tokens).
# Sign up at: https://auth0.com and enable Token Vault for AI Agents
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_REDIRECT_URI=https://your-domain.com/api/consent/callback

# ── AssistantX operating mode ─────────────────────────────────────────────────────
# "demo"   → proxy all instances to a single OpenClaw server on the host
# "docker" → spin up one isolated Docker container per instance (production)
# ASSISTANTX_MODE=demo

# ── OpenClaw gateway (demo mode) ─────────────────────────────────────────────
# Start OpenClaw on the host with: openclaw gateway --port 18789
# Then set GOOGLE_GENERATIVE_AI_API_KEY (or ANTHROPIC_API_KEY) and start AssistantX.
# OPENCLAW_HOST=127.0.0.1
# OPENCLAW_PORT=18789

# ── OpenClaw container config (docker mode) ───────────────────────────────────
# Docker image to use for OpenClaw instances
# OPENCLAW_IMAGE=node:22-slim
# Max concurrent instances
# MAX_INSTANCES=10

